# ═══════════════════════════════════════════════════════════════════
# Terraform Variables — Production Level (EKS Auto Mode)
# Copy to terraform.tfvars and fill values
# NEVER commit terraform.tfvars with real values!
# ═══════════════════════════════════════════════════════════════════

aws_region      = "eu-west-2"
environment     = "production"
github_org      = "chimdi247"
github_repo     = "Food-Delivery"
cluster_name    = "food-delivery-cluster"
cluster_version = "1.34"

# Bastion Server (runs SonarQube + connects to EKS)
bastion_instance_type = "t3.medium"   # 2 vCPU, 4GB RAM (enough for SonarQube)

# Connect to bastion via SSM Session Manager (no SSH key needed):
#   aws ssm start-session --target <instance-id> --region eu-west-2
